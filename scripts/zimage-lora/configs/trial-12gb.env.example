# Copy to trial-12gb.env and edit values before running train-trial.sh

# Required for model download
HF_TOKEN=

# Optional experiment tracking; leave empty for none
WANDB_API_KEY=

# Dataset identity
CHARACTER_ID=sample-character
TRAINING_NAME=sample-character-trial

# Workspace paths; relative paths resolve from repo root when sourced by the scripts
ZLORA_WORK_ROOT=./scripts/zimage-lora/workspace
ZLORA_DATASET_ROOT=./scripts/zimage-lora/workspace/datasets
ZLORA_RUNTIME_ROOT=./scripts/zimage-lora/workspace/runtime
ZLORA_OUTPUT_ROOT=./scripts/zimage-lora/workspace/output
ZLORA_CACHE_ROOT=./scripts/zimage-lora/workspace/cache
ZLORA_HF_HOME=./scripts/zimage-lora/workspace/huggingface
ZLORA_REUSE_ROOT=./scripts/zimage-lora/workspace/reuse
ZLORA_LOG_ROOT=./scripts/zimage-lora/workspace/logs

# Docker / image
ZLORA_IMAGE_NAME=photopainter-simpletuner:local
ZLORA_PYTHON_VERSION=3.12
SIMPLETUNER_BRANCH=release
ZLORA_COMPOSE_PROJECT_NAME=photopainter-zlora
ZLORA_SHM_SIZE=16gb

# Trial profile
ZLORA_DATASET_REPEATS=20
ZLORA_MIN_IMAGE_COUNT=8
ZLORA_MAX_TRAIN_STEPS=400
ZLORA_PRIMARY_VALIDATION_PROMPT=portrait of sample-character, same character identity, clean anime illustration

# Fallback toggles
ZLORA_FORCE_INT8=0
ZLORA_FORCE_FP16=0
ZLORA_DISABLE_GROUP_OFFLOAD=0

# Optional existing local inference command for validate-reuse.sh
# Available placeholders:
#   __ARTIFACT__
#   __PROMPT_LIBRARY__
#   __OUTPUT_DIR__
#   __RUN_DIR__
#   __TRAINING_NAME__
VALIDATE_REUSE_COMMAND=

# 共通 RunPod ComfyUI Docker Compose 環境変数テンプレート
# このファイルを .env にコピーして値を編集してください:
#   cp .env.example .env

# HTTP server 公開ポート（host 側）
SERVER_EXPOSE_PORT=8000

# HTTP server の配信データディレクトリ（host 側）
SERVER_CONTENT_DIR=./server/contents

# ComfyUI ポート（ホスト側、デフォルト 18188）
COMFYUI_PORT=18188

# local でも /runpod-volume として bind mount する host 側ディレクトリ
# 事前に models、ollama/models、input、output、user、dot-cache、dot-local を作成する
# 例: RUNPOD_VOLUME_DIR=/mnt/data/runpod-volume
RUNPOD_VOLUME_DIR=./runpod-volume

# ComfyUI 起動フラグ（省略時: --listen 0.0.0.0 --fast --enable-manager）
# 共有 runtime は local / RunPod とも同じ image を使う
# COMFYUI_CLI_ARGS=--listen 0.0.0.0 --fast --enable-manager

# build 時に comfy-node-install へ渡す追加 custom node 一覧
# カンマ区切りで複数指定する
# COMFYUI_CUSTOM_NODES=https://github.com/yolain/ComfyUI-Easy-Use,https://github.com/stavsap/comfyui-ollama,https://github.com/StableLlama/ComfyUI-basic_data_handling

# LLM model cache ディレクトリ（必要な場合のみ指定）
# `PhotoPainter LLM Generate` node が container 内で参照する保存先
# 省略時は backend 既定保存先を使う
# COMFYUI_LLM_MODEL_CACHE_DIR=./runpod-volume/llm-models

# 起動時に事前 pull したい Ollama model 一覧（カンマ区切り）
# 例: OLLAMA_PULL_MODELS=qwen3.5:4b,llama3.2:3b
# OLLAMA_PULL_MODELS=

# AI Toolkit UI ポート（ホスト側、デフォルト 8675）
AI_TOOLKIT_PORT=8675

# AI Toolkit データディレクトリ（config / datasets / output / DB / cache / db の親ディレクトリ）
# 絶対パスまたは compose.yml 相対パスで指定可能
# 例: AI_TOOLKIT_DATA_DIR=/mnt/data/ai-toolkit
AI_TOOLKIT_DATA_DIR=./ai-toolkit-data

# AI Toolkit UI の認証トークン
# ローカル試用では既定値のままでもよいが、共有環境では変更を推奨
AI_TOOLKIT_AUTH=password
